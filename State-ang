interface UserFormValue {
  name: string;
  email: string;
  address: {
    street: string;
    city: string;
  };
}

@Component({
  providers: [FormStateService<UserFormValue>], // note: see caveat below
})
export class UserTabComponent implements OnInit, OnDestroy {
  form = this.fb.group({
    name: this.fb.control('', { nonNullable: true }),
    email: this.fb.control('', { nonNullable: true }),
    address: this.fb.group({
      street: this.fb.control('', { nonNullable: true }),
      city: this.fb.control('', { nonNullable: true }),
    }),
  });

  constructor(
    private fb: FormBuilder,
    private formState: FormStateService<UserFormValue>,
    private userService: UserService,
  ) {}

  ngOnInit() {
    this.formState.init(this.form);
    this.formState.registerDependency('user-http');

    this.userService.getUser().subscribe(user => {
      this.form.patchValue(user);
      this.formState.resolveDependency('user-http');
    });
  }

  onSave() {
    const value = this.formState.getCurrentValue();
    if (!value) return;

    this.formState
      .save<UserFormValue>(this.userService.updateUser(value))
      .subscribe({
        error: () => this.toast.error('Save failed'),
      });
  }

  onDiscard() {
    this.formState.discard();
  }

  ngOnDestroy() {
    this.formState.destroy();
  }
}
